{
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-preset-recommend"
    },
    {
      "id": "@secretlint/secretlint-rule-pattern",
      "options": {
        "patterns": [
          {
            "name": "aws-access-key",
            "pattern": "/AWS\\s*=\\s*[a-zA-Z0-9/+=]{40}/i",
            "message": "Foi detectada uma possível chave AWS com nome genérico."
          },
          {
            "name": "generic-secret",
            "pattern": "\\b(password|secret|api[_-]?key|token)\\b\\s*[:=]\\s*['\"]?[A-Za-z0-9/+=!@#$%^&*()_\\-]{8,}['\"]?",
            "message": "Foi detectada uma possível chave/key com nome genérico."
          },
          {
            "name": "generic-strong-secret",
            "pattern": "[:=]\\s*['\"]?(?=[A-Za-z0-9+/=]{20,})(?=.*[A-Za-z])(?=.*[0-9])[A-Za-z0-9+/=]+['\"]?",
            "message": "Possível segredo forte hardcoded detectado."
          },
          {
            "name": "generic-long-secret",
            "pattern": "[=:]\\s*['\"]?[A-Za-z0-9+/]{32,}"
          },
          {
            "name": "generic-long-secret2",
            "pattern": "[A-Za-z0-9+/]{40,}",
            "message": "Possível segredo longo detectado."
          },
          {
            "name": "generic-secrets",
            "pattern": "(?<==\\s*[\"']?)(?=[^\"']*?\\d)(?=[^\"']*?[A-Z])(?=[^\"']*?[a-z])[a-zA-Z0-9\\/\\+]{12,64}(?=[\"']?)"
          },
          {
            "name": "generic-secrets2",
            "pattern": "(?<==\\s*[\"']?)[a-zA-Z0-9\\/\\+\\-_!@#$%^&*]{12,64}(?=[\"']?)"
          }
        ]
      }
    }
  ]
}
